<Window x:Class="Toimistotilojen_varausjarjestelma.Raportit"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Toimistotilojen_varausjarjestelma"
        mc:Ignorable="d"
        Title="Raportit" Height="600" Width="1000"
        Background="{StaticResource BrandBackgroundColor}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Raportit"
                   FontSize="28"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="WhiteSmoke"
                    CornerRadius="8"
                    Padding="20"
                    Margin="0,0,20,0">
                <StackPanel>
                    <TextBlock Text="Raportin valinta"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,0,0,20"/>

                    <TextBlock Text="Toimipiste:"
                               FontWeight="SemiBold"
                               Margin="0,0,0,5"/>
                    <ComboBox x:Name="CmbToimipiste"
                              Margin="0,0,0,15"
                              SelectedIndex="0">
                        <ComboBoxItem Content="Kaikki"/>
                        <ComboBoxItem Content="Joensuu"/>
                        <ComboBoxItem Content="Kuopio"/>
                        <ComboBoxItem Content="Tampere"/>
                    </ComboBox>

                    <TextBlock Text="Alkupäivä:"
                               FontWeight="SemiBold"
                               Margin="0,0,0,5"/>
                    <DatePicker x:Name="DpAlku"
                                Margin="0,0,0,15"/>

                    <TextBlock Text="Loppupäivä:"
                               FontWeight="SemiBold"
                               Margin="0,0,0,5"/>
                    <DatePicker x:Name="DpLoppu"
                                Margin="0,0,0,20"/>

                    <Button Content="Luo raportti"
                            Height="45"
                            Click="LuoRaportti_Click"/>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBox x:Name="TxtRaportti"
                         Grid.Row="0"
                         Background="White"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         FontSize="15"
                         Padding="15"/>

                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,15,0,0">
                    <Button Content="Tyhjennä"
                            Width="120"
                            Margin="0,0,10,0"
                            Click="Tyhjenna_Click"/>
                    <Button Content="Takaisin valikkoon"
                            Width="180"
                            Background="LightPink"
                            Click="Takaisin_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
