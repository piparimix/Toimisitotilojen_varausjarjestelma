<Window x:Class="Toimistotilojen_varausjarjestelma.Kaikki_varaukset"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Toimistotilojen_varausjarjestelma"
        mc:Ignorable="d"
        Title="Kaikki varaukset" Height="600" Width="1000">

    <Border Background="{StaticResource BrandBackgroundColor}" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Kaikki varaukset"
                       FontSize="28"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="White" Padding="15" CornerRadius="5" Margin="0,0,15,0">
                    <StackPanel>
                        <TextBlock Text="Varausten hallinta" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

                        <TextBlock Text="Haku:" FontWeight="SemiBold" Margin="0,5,0,2"/>
                        <TextBox x:Name="TxtHaku" Margin="0,0,0,10"/>

                        <TextBlock Text="Toimipiste:" FontWeight="SemiBold" Margin="0,5,0,2"/>
                        <ComboBox x:Name="CmbToimipiste" Margin="0,0,0,10" SelectedIndex="0">
                            <ComboBoxItem Content="Kaikki"/>
                            <ComboBoxItem Content="Joensuu"/>
                            <ComboBoxItem Content="Kuopio"/>
                            <ComboBoxItem Content="Tampere"/>
                        </ComboBox>

                        <Button Content="Hae varaukset" />
                    </StackPanel>
                </Border>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="DgVaraukset"
                              Grid.Row="0"
                              AutoGenerateColumns="False"
                              Background="White"
                              IsReadOnly="True"
                              HeadersVisibility="Column" Margin="0,0,0,61" Grid.RowSpan="2">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Asiakas" Binding="{Binding Asiakas}" Width="*"/>
                            <DataGridTextColumn Header="Toimipiste" Binding="{Binding Toimipiste}" Width="120"/>
                            <DataGridTextColumn Header="Tila" Binding="{Binding Tila}" Width="120"/>
                            <DataGridTextColumn Header="Alkaa" Binding="{Binding Alkaa}" Width="120"/>
                            <DataGridTextColumn Header="Päättyy" Binding="{Binding Paattyy}" Width="120"/>

                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                        <Button Content="Takaisin valikkoon" Click="Takaisin_Click" Background="#FFFFB6C1"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
