<Window x:Class="Toimistotilojen_varausjarjestelma.Asiakkaat"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Asiakkaat" Height="600" Width="950">

    <Border Background="{StaticResource BrandBackgroundColor}" Padding="20">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" Padding="15" CornerRadius="5" Margin="0,0,15,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Asiakkaan tiedot" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

                        <TextBlock Text="Asiakastyyppi:" FontWeight="SemiBold" Margin="0,5,0,2"/>
                        <ComboBox x:Name="CmbAsiakasTyyppi" Margin="0,0,0,10" SelectedIndex="0">
                            <ComboBoxItem Content="Yksityishenkilö"/>
                            <ComboBoxItem Content="Yritys"/>
                            <ComboBoxItem Content="Organisaatio"/>
                        </ComboBox>

                        <TextBlock FontWeight="SemiBold" Margin="0,5,0,2">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Nimi:"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementName=CmbAsiakasTyyppi, Path=Text}" Value="Yritys">
                                            <Setter Property="Text" Value="Yrityksen nimi:"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ElementName=CmbAsiakasTyyppi, Path=Text}" Value="Organisaatio">
                                            <Setter Property="Text" Value="Organisaation nimi:"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox x:Name="TxtNimi" Margin="0,0,0,10" Padding="3"/>

                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementName=CmbAsiakasTyyppi, Path=Text}" Value="Yksityishenkilö">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <TextBlock Text="Y-tunnus:" FontWeight="SemiBold" Margin="0,5,0,2"/>
                            <TextBox x:Name="TxtYTunnus" Margin="0,0,0,10" Padding="3"/>
                        </StackPanel>

                        <TextBlock Text="Sähköposti:" FontWeight="SemiBold" Margin="0,5,0,2"/>
                        <TextBox x:Name="TxtSahkoposti" Margin="0,0,0,10" Padding="3"/>

                        <TextBlock Text="Puhelinnumero:" FontWeight="SemiBold" Margin="0,5,0,2"/>
                        <TextBox x:Name="TxtPuhelin" Margin="0,0,0,10" Padding="3"/>

                        <TextBlock Text="Osoite (Laskutusta varten):" FontWeight="SemiBold" Margin="0,5,0,2"/>
                        <TextBox x:Name="TxtOsoite" Margin="0,0,0,15" Padding="3" Height="50" TextWrapping="Wrap" AcceptsReturn="True"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                        <Button Content="Tyhjennä"/>
                        <Button Content="Tallenna" Background="#FF90EE90"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                    <TextBlock Text="Hae asiakasta:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold" FontSize="18"/>
                    <TextBox x:Name="TxtHaku" Width="250" Padding="3" VerticalContentAlignment="Center"/>
                    <Button Content="Etsi"  Width="70" Padding="2"/>
                </StackPanel>

                <DataGrid x:Name="DgAsiakkaat" Grid.Row="1" AutoGenerateColumns="False" Background="White" IsReadOnly="True" HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nimi / Yritys" Binding="{Binding Nimi}" Width="*"/>
                        <DataGridTextColumn Header="Tyyppi" Binding="{Binding Tyyppi}" Width="100"/>
                        <DataGridTextColumn Header="Puhelin" Binding="{Binding Puhelin}" Width="120"/>
                        <DataGridTextColumn Header="Laskutus" Binding="{Binding Laskutustapa}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                    <Button Content="Muokkaa valittua"/>
                    <Button Content="Poista valittu" Background="#FFFFB6C1"/>
                    <Button Content="Takaisin valikkoon" HorizontalAlignment="Left" Click="Takaisin_Click" Background="#FFFFB6C1"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>