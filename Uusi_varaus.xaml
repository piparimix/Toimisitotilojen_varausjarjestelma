<Window x:Class="Toimistotilojen_varausjarjestelma.Uusi_varaus"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Toimistotilojen_varausjarjestelma"
        mc:Ignorable="d"
        Title="Uusi varaus" Height="450" Width="741">
    <Border Background="{StaticResource BrandBackgroundColor}" Padding="20">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" Padding="15" CornerRadius="5" Margin="0,0,15,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Varauksen tiedot" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

                        <TextBlock Text="Asiakas:" FontWeight="SemiBold" Margin="0,5,0,2"/>
                        <ComboBox x:Name="CmbAsiakasTyyppi" Margin="0,0,0,10" SelectedIndex="0">
                            <ComboBoxItem Content="Pertti Heikkinen"/>
                            <ComboBoxItem Content="Heikki Perttinen"/>
                            <ComboBoxItem Content="Pertin Heikki"/>
                        </ComboBox>

                        <TextBlock Text="Toimitila:" FontWeight="SemiBold" Margin="0,0,0,2"/>
                        <ComboBox x:Name="CmbToimitilaTyyppi" Margin="0,0,0,10" SelectedIndex="0">
                            <ComboBoxItem Content="Timantti, Joensuu"/>
                            <ComboBoxItem Content="Graniitti, Joensuu"/>
                            <ComboBoxItem Content="Loiste, Tampere"/>
                        </ComboBox>

                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <StackPanel>
                                <TextBlock Text="Varaus alkaa:" Margin="0,0,0,5"/>
                                <DatePicker Width="140"/>
                            </StackPanel>

                            <StackPanel Margin="20,0,0,0">
                                <TextBlock Text="Varaus päättyy:" Margin="0,0,0,5"/>
                                <DatePicker Width="140"/>
                            </StackPanel>

                        </StackPanel>

                        <Label   Content="Lisätietoja" Grid.Row="1" Grid.Column="0"  Grid.RowSpan="2" FontStyle="Italic" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtDescription"  Grid.Row="1" Grid.Column="0"    Height="100"  Background="#FFDCF4F7" Grid.RowSpan="2" Margin="5,5,5,5"/>



                    </StackPanel>


                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>


                <StackPanel>
                    <TextBlock Text="Palvelut:" FontWeight="SemiBold" Margin="0,15,0,5"/>

                    <ListBox x:Name="PalvelutListBox" Height="120" ScrollViewer.HorizontalScrollBarVisibility="Auto"/>

                    <TextBlock Text="Laitteet:" FontWeight="SemiBold" Margin="0,15,0,0"/>

                    <ListBox x:Name="LaitteetListBox" Height="120" ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                </StackPanel>








                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,20"  >
                    <Button Content="Luo varaus" Background="#FF90EE90"/>
                    <Button Content="Takaisin valikkoon"  Background="#FFFFB6C1" Click="Button_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>

</Window>
