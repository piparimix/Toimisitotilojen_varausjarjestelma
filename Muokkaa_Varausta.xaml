<Window x:Class="Toimistotilojen_varausjarjestelma.Muokkaa_Varausta"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Toimistotilojen_varausjarjestelma"
        mc:Ignorable="d"
        Title="Muokkaa varausta" Height="600" Width="900">
    <Border Background="{StaticResource BrandBackgroundColor}" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" CornerRadius="5" Margin="0,0,0,15">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Etsi varaus ID:llä tai nimellä:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,5,0"/>
                    <TextBox x:Name="TxtSearch" Width="250" VerticalContentAlignment="Center" Height="30" />
                    <Button Content="Hae" Background="#FFADD8E6"/>
                </StackPanel>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="340"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="White" Padding="15" CornerRadius="5" Margin="0,0,15,0">
                    <StackPanel>
                        <TextBlock Text="Muokkaa varauksen tietoja" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

                        <TextBlock Text="Asiakas:" FontWeight="SemiBold" Margin="0,5,0,2"/>
                        <ComboBox x:Name="CmbAsiakasTyyppi" Margin="0,0,0,10" SelectedIndex="0">
                            <ComboBoxItem Content="Pertti Heikkinen"/>
                        </ComboBox>

                        <TextBlock Text="Toimitila:" FontWeight="SemiBold" Margin="0,0,0,2"/>
                        <ComboBox x:Name="CmbToimitilaTyyppi" Margin="0,0,0,10" SelectedIndex="0">
                            <ComboBoxItem Content="Timantti, Joensuu"/>
                        </ComboBox>

                        <StackPanel Orientation="Horizontal" Margin="0,10,0,10">
                            <StackPanel>
                                <TextBlock Text="Varaus alkaa:" Margin="0,0,0,5"/>
                                <DatePicker Width="135"/>
                            </StackPanel>
                            <StackPanel Margin="15,0,0,0">
                                <TextBlock Text="Varaus päättyy:" Margin="0,0,0,5"/>
                                <DatePicker Width="135"/>
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Text="Lisätietoja" FontStyle="Italic" FontWeight="Bold" FontSize="14" Margin="0,5,0,5"/>
                        <TextBox x:Name="txtDescription" Height="100" Background="#FFDCF4F7" TextWrapping="Wrap" AcceptsReturn="True"/>
                    </StackPanel>
                </Border>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Palvelut:" FontWeight="SemiBold" Margin="0,0,0,5"/>

                        <ListBox x:Name="PalvelutListBox" Height="100" ScrollViewer.VerticalScrollBarVisibility="Auto"/>

                        <TextBlock Text="Laitteet:" FontWeight="SemiBold" Margin="0,15,0,5"/>

                        <ListBox x:Name="LaitteetListBox" Height="120" ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>
                    <WrapPanel Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,10,0,0">
                        <Button Content="Poista varaus" Background="#FFFF6347"/>
                        <Button Content="Tallenna muutokset" Background="#FF90EE90" />
                        <Button Content="Takaisin" Background="#FFFFB6C1" Click="Takaisin_Click" />
                    </WrapPanel>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>