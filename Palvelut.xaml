<Window x:Class="Toimistotilojen_varausjarjestelma.Palvelut"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Toimistotilojen_varausjarjestelma"
        mc:Ignorable="d"
        Title="Palvelut" Height="450" Width="800"
        Background="{StaticResource BrandBackgroundColor}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="Takaisin Päävalikkoon" Background="#FFFFB6C1" Click="Takaisin_Click" Padding="15,8" HorizontalAlignment="Left"/>

            <TextBlock Grid.Column="1" Text="Hallinta: Palvelut ja Laitteet" FontSize="28" FontWeight="Bold" Foreground="#FF111111" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="76,0,0,0"/>
        </Grid>

        <TabControl Grid.Row="1" Background="White" BorderBrush="Black" Margin="0,10,0,0">

            <TabItem Header="Palvelut" FontSize="16" Padding="20,10" BorderBrush="Black">
                <Grid Margin="15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="220"/>
                    </Grid.ColumnDefinitions>

                    <DataGrid Grid.Column="0" Name="PalvelutDataGrid" AutoGenerateColumns="False" CanUserAddRows="False" Background="White" RowHeight="35" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nimi" Binding="{Binding Nimi}" Width="2*"/>
                            <DataGridTextColumn Header="Hinta (€/h)" Binding="{Binding Hinta}" Width="*"/>
                            <DataGridTextColumn Header="Kuvaus" Binding="{Binding Kuvaus}" Width="3*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Column="1" Margin="15,0,0,0">
                        <Button Content="Lisää uusi palvelu" Click="LisaaPalvelu_Click" />
                        <Button Content="Muokkaa valittua"/>

                        <Border Height="60"/>
                        <Button Content="Poista palvelu" Background="#FFFFB6C1"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Laitteet" FontSize="16" Padding="20,10">
                <Grid Margin="15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="220"/>
                    </Grid.ColumnDefinitions>

                    <DataGrid Grid.Column="0" Name="LaitteetDataGrid" AutoGenerateColumns="False" CanUserAddRows="False" Background="White" RowHeight="35" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nimi" Binding="{Binding Nimi}" Width="2*"/>
                            <DataGridTextColumn Header="Määrä (kpl)" Binding="{Binding Maara}" Width="*"/>
                            <DataGridTextColumn Header="Kunto" Binding="{Binding Kunto}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Column="1" Margin="15,0,0,0">
                        <Button Content="Lisää uusi laite" Click="LisaaLaite_Click"/>
                        <Button Content="Muokkaa valittua"/>

                        <Border Height="60"/>
                        <Button Content="Poista laite" Background="#FFFFB6C1"/>
                    </StackPanel>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
