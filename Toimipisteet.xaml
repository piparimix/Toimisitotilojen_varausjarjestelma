<Window x:Class="Toimistotilojen_varausjarjestelma.Toimipisteet"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Toimistotilojen_varausjarjestelma"
        mc:Ignorable="d"
        Title="Toimipisteet" Height="450" Width="800">
    <Border Background="{StaticResource BrandBackgroundColor}" Padding="20">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" Padding="15" CornerRadius="5" Margin="0,0,15,0">
                <StackPanel>
                    <TextBlock Text="Toimipisteen tiedot" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>
                    <TextBlock Text="Nimi:" FontWeight="SemiBold"/>
                    <TextBox x:Name="TxtToimipisteNimi" Margin="0,5,0,10"/>

                    <TextBlock Text="Kaupunki:" FontWeight="SemiBold"/>
                    <TextBox x:Name="TxtKaupunki" Margin="0,5,0,10"/>

                    <Button Content="Tallenna toimipiste" Background="#FF90EE90" Margin="0,20,0,0"/>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid x:Name="DgToimipisteet" AutoGenerateColumns="False" Background="White">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Toimipiste" Binding="{Binding Nimi}" Width="*"/>
                        <DataGridTextColumn Header="Kaupunki" Binding="{Binding Kaupunki}" Width="150"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                    <Button Content="Poista" Background="#FFFFB6C1"/>
                    <Button Content="Takaisin" Click="Takaisin_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
