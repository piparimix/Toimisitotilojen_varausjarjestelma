<Window x:Class="Toimistotilojen_varausjarjestelma.LisaaLaite"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Toimistotilojen_varausjarjestelma"
        mc:Ignorable="d"
        Title="Lisää uusi laite" Height="600" Width="950">

    <Border Background="{StaticResource BrandBackgroundColor}" Padding="20">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" Padding="15" CornerRadius="5" Margin="0,0,15,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Laitteen tiedot" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

                        <TextBlock Text="Nimi:" FontWeight="SemiBold" Margin="0,5,0,2"/>
                        <TextBox x:Name="TxtNimi" Margin="0,0,0,10" Padding="3"/>

                        <TextBlock Text="Määrä (kpl)::" FontWeight="SemiBold" Margin="0,5,0,2"/>
                        <TextBox x:Name="TxtMaara" Margin="0,0,0,10" Padding="3"/>

                        <TextBlock Text="Kunto:" FontWeight="SemiBold" Margin="0,5,0,2"/>
                        <TextBox x:Name="TxtKunto" Margin="0,0,0,10" Padding="3" Height="86"/>


                    </StackPanel>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                        <Button Content="Tyhjennä"/>
                        <Button Content="Tallenna" Background="#FF90EE90"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                    <TextBlock Text="Hae laitetta:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold" FontSize="18"/>
                    <TextBox x:Name="TxtHaku" Width="250" Padding="3" VerticalContentAlignment="Center"/>
                    <Button Content="Etsi"  Width="70" Padding="2"/>
                </StackPanel>

                <DataGrid x:Name="DgLaitteet" Grid.Row="1" AutoGenerateColumns="False" Background="White" IsReadOnly="True" HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nimi" Binding="{Binding Nimi}" Width="*"/>
                        <DataGridTextColumn Header="Määrä (kpl)" Binding="{Binding Maara}" Width="100"/>
                        <DataGridTextColumn Header="Kunto" Binding="{Binding Kunto}" Width="120"/>

                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                    <Button Content="Muokkaa valittua"/>
                    <Button Content="Poista valittu" Background="#FFFFB6C1"/>
                    <Button Content="Takaisin valikkoon" HorizontalAlignment="Left" Click="Takaisin_Click"  Background="#FFFFB6C1"/>
                </StackPanel>

            </Grid>
        </Grid>
    </Border>
</Window>
